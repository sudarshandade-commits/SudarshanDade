body {
  margin: 0;
  font-family: Arial;
  background: #f4f4f4;
  transition: 0.3s;
}

header {
  display: flex;
  justify-content: space-between;
  background: #222;
  color: white;
  padding: 10px;
}

nav {
  text-align: center;
  background: #444;
  padding: 10px;
}

nav a {
  color: white;
  margin: 10px;
  text-decoration: none;
}

section {
  padding: 40px;
  text-align: center;
}

.profile {
  width: 150px;
  border-radius: 50%;
}

.card {
  display: inline-block;
  background: white;
  padding: 15px;
  margin: 10px;
  width: 250px;
  border-radius: 10px;
}

.card img {
  width: 100%;
}

#gallery img {
  width: 150px;
  margin: 10px;
}

/* DARK MODE */
.dark {
  background: #121212;
  color: white;
}

.dark header, .dark nav {
  background: black;
}

.dark .card {
  background: #1e1e1e;
}
